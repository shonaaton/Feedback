        "jsCode": "const raw = $input.first().json;\nconst body = raw.body || raw;\nconst query = raw.query || {};\nreturn [{ json: { ...query, ...body, action: body.action || query.action || 'ping' } }];"
      },
      "id": "normalize-write-request",
