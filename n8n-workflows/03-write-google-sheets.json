      "name": "Read OTP Store",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        -400,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const request = $('Normalize Write Request').item.json;\nconst sessions = $input.all().map(i=>i.json);\nconst norm = v => String(v||'').trim().toLowerCase();\nconst token = String(request.sessionToken || '').trim();\nif (!token) throw new Error('Missing session token. Please login again.');\nconst match = sessions.filter(r=>String(r.SessionToken||'').trim()===token && norm(r.Used)==='true').sort((a,b)=>new Date(b.UsedAt||b.CreatedAt||0)-new Date(a.UsedAt||a.CreatedAt||0))[0];\nif (!match) throw new Error('Invalid or expired session. Please login again.');\nconst usedAt = new Date(match.UsedAt||match.CreatedAt||'').getTime();\nif (!usedAt || Number.isNaN(usedAt) || Date.now() > usedAt + 12*60*60*1000) throw new Error('Session expired. Please login again.');\nreturn [{ json: { ...request, sessionEmail: norm(match.Email), sessionRole: norm(match.Role) } }];"
      },
      "id": "validate-write-session",
      "name": "Validate Write Session",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -150,
        0
      ]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "1S-GPXYvwwk_QYhd4G2GS1uloO5tBx0yq0HoEah9d2F8",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Portal_Tasks",
          "mode": "name"
        },
        "options": {}
      },
      "id": "read-portal-tasks",
      "name": "Read Portal Tasks",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        100,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const req = $('Validate Write Session').item.json;\nconst tasks = $input.all().map(i=>i.json);\nconst norm = v => String(v||'').trim().toLowerCase();\nconst get = (row, keys, fallback='') => { for (const k of keys) { if (row[k] !== undefined && row[k] !== null && String(row[k]).trim() !== '') return row[k]; } return fallback; };\nlet payload = req.payload || req;\nif (typeof payload === 'string') payload = JSON.parse(payload);\nconst feedback = payload.feedback || {};\nconst taskId = String(payload.taskId || req.taskId || '').trim();\nif (!taskId) throw new Error('Missing taskId.');\nconst task = tasks.find(t=>String(get(t,['Task_ID','taskId'])).trim() === taskId);\nif (!task) throw new Error('Task not found in Portal_Tasks.');\nconst coachEmail = norm(get(task,['Coach_Email','coachEmail']));\nif (req.sessionRole === 'coach' && coachEmail !== req.sessionEmail) throw new Error('This task is not assigned to this coach.');\nconst action = req.action;\nconst mode = payload.mode || req.mode || (action === 'mentor_update' ? 'mentor' : 'submit');\nif (action === 'mentor_update' && req.sessionRole !== 'mentor') throw new Error('Mentor access required.');\nconst now = new Date().toISOString();\nconst mentorStatus = payload.mentorStatus || (action === 'mentor_update' ? 'Approved' : 'Pending');\nconst submissionStatus = action === 'mentor_update' ? 'Reviewed' : (mode === 'draft' ? 'Draft' : 'Submitted');\nconst row = {\n  Submission_ID: 'SUB-' + Date.now().toString(36).toUpperCase() + '-' + Math.random().toString(36).slice(2,7).toUpperCase(),\n  Task_ID: taskId,\n  Month: get(task,['Month']),\n  Coach_ID: get(task,['Coach_ID']),\n  Coach_Name: get(task,['Coach_Name']),\n  Coach_Email: get(task,['Coach_Email']),\n  Student_ID: get(task,['Student_ID']),\n  Student_Name: get(task,['Student_Name']),\n  Student_Email: get(task,['Student_Email']),\n  Lichess_ID: get(task,['Lichess_ID']),\n  Batch_Code: get(task,['Batch_Code']),\n  Student_Rating: feedback.studentRating || get(task,['Student_Rating']),\n  Games_Played: feedback.gamesPlayed || '',\n  Wins: feedback.wins || '',\n  Draws: feedback.draws || '',\n  Losses: feedback.losses || '',\n  Rating_Change: feedback.ratingChange || '',\n  Puzzle_Activity: feedback.puzzleActivity || '',\n  Best_Result: feedback.bestResult || '',\n  Puzzle_Consistency: feedback.puzzleConsistency || '',\n  Skill_Level: feedback.skillLevel || '',\n  Class_Performance: feedback.classPerformance || '',\n  Strengths: feedback.strengths || '',\n  Improvement_Areas: feedback.improvementAreas || '',\n  Focus_Next_Month: feedback.focusNextMonth || '',\n  Overall_Comment: feedback.overallComment || '',\n  Mentor_Remark: feedback.mentorRemark || '',\n  Mentor_Notes: feedback.mentorNotes || '',\n  Submission_Status: submissionStatus,\n  Mentor_Status: mentorStatus,\n  Submitted_On: action === 'submit_feedback' ? now : '',\n  Reviewed_On: action === 'mentor_update' && mentorStatus === 'Approved' ? now : '',\n  Returned_On: action === 'mentor_update' && mentorStatus === 'Returned' ? now : '',\n  Last_Updated: now,\n  Mode: mode\n};\nreturn [{ json: row }];"
      },
