        "sendTo": "={{ $('Generate OTP').item.json.Email }}",
        "subject": "Envision Chess Academy login code",
        "message": "=<div style=\"font-family:Segoe UI,Arial,sans-serif;max-width:560px;padding:24px\"><h2 style=\"color:#5A1372;margin:0 0 12px\">Your login code</h2><p style=\"color:#444;line-height:1.6\">Use this one-time code to sign in to the Envision Chess Academy feedback portal.</p><div style=\"font-size:36px;font-weight:800;letter-spacing:0.2em;color:#5A1372;background:#f7f1fb;border-radius:12px;padding:18px 24px;margin:20px 0;display:inline-block\">{{ $('Generate OTP').item.json.Code }}</div><p style=\"color:#888;font-size:0.9rem\">This code expires in 10 minutes. Do not share it with anyone.</p></div>",
        "options": {
          "senderName": "Envision Chess Academy"
        }
      },
