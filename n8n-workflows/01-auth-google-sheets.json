    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst body = raw.body || raw;\nconst email = String(body.email || '').trim().toLowerCase();\nlet role = String(body.role || '').trim().toLowerCase();\nif (role === 'admin') role = 'mentor';\nif (!email) throw new Error('Email is required');\nif (!['coach','mentor'].includes(role)) throw new Error('Role must be coach or mentor');\nconst createdAt = new Date().toISOString();\nconst expiresAt = new Date(Date.now() + 10 * 60 * 1000).toISOString();\nconst code = String(Math.floor(100000 + Math.random() * 900000));\nconst otpId = `${email}|${role}|${Date.now()}|${Math.random().toString(36).slice(2,10)}`;\nreturn [{ json: { OtpId: otpId, Email: email, Role: role, Code: code, ExpiresAt: expiresAt, Used: 'FALSE', SessionToken: '', CreatedAt: createdAt, UsedAt: '' } }];"
      },
