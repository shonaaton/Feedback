      "id": "read-otp-store",
      "name": "Read OTP Store",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        -380,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "const req = $('Extract Verify Payload').item.json;\nconst rows = $input.all().map(i => i.json);\nconst norm = v => String(v || '').trim().toLowerCase();\nconst matches = rows\n  .filter(r => norm(r.Email) === req.email)\n  .filter(r => norm(r.Role) === req.role)\n  .filter(r => String(r.Code || '').trim() === req.code)\n  .filter(r => norm(r.Used) !== 'true')\n  .sort((a,b) => new Date(b.CreatedAt || 0).getTime() - new Date(a.CreatedAt || 0).getTime());\nif (!matches.length) throw new Error('OTP not found or already used. Please request a fresh code.');\nconst otp = matches[0];\nconst exp = new Date(otp.ExpiresAt || '').getTime();\nif (!exp || Number.isNaN(exp) || Date.now() > exp) throw new Error('OTP expired. Please request a fresh code.');\nconst token = 'sess_n8n_' + Math.random().toString(36).slice(2) + '_' + Date.now().toString(36);\nreturn [{ json: { OtpId: otp.OtpId, Email: req.email, Role: req.role, Code: otp.Code, ExpiresAt: otp.ExpiresAt, Used: 'TRUE', SessionToken: token, CreatedAt: otp.CreatedAt || '', UsedAt: new Date().toISOString() } }];"
      },
