          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.AUTOMATION_SECRET}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { action: 'claim_jobs', type: 'parent-delivery', limit: 25 } }}",
        "options": {}
      },
      "id": "claim-parent-jobs",
      "name": "Claim Parent Jobs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -210,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const jobs = (($input.first().json.data || {}).jobs || []);\nreturn jobs.map(job => ({ json: job }));"
      },
      "id": "split-parent-jobs",
      "name": "Split Parent Jobs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        30,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.PORTAL_AUTOMATION_URL}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.AUTOMATION_SECRET}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { action: 'parent_delivery_payload', taskId: $json.payload.taskId } }}",
        "options": {}
      },
      "id": "get-parent-payload",
      "name": "Get Parent Payload",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        290,
        0
      ]
    },
    {
      "parameters": {
        "sendTo": "={{$node['Split Parent Jobs'].json.payload.parentEmail}}",
        "subject": "=Monthly feedback report for {{$json.data.studentName}} - {{$json.data.month}}",
        "emailType": "html",
        "message": "={{$json.data.html}}",
        "options": {}
      },
      "id": "send-parent-email",
      "name": "Send Parent Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        560,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.PORTAL_AUTOMATION_URL}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.AUTOMATION_SECRET}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { action: 'complete_job', jobId: $node['Split Parent Jobs'].json._id, result: { sentTo: $node['Split Parent Jobs'].json.payload.parentEmail } } }}",
        "options": {}
      },
      "id": "complete-parent-job",
      "name": "Complete Parent Job",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        830,
        0
      ]
    }
